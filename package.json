{
  "name": "bnext",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "author": "",
  "license": "ISC",
  "scripts": {
    "start": "NODE_ENV=production node src/index.js",
    "dev": "cross-env NODE_ENV=development nodemon src/index.js",
    "test": "jest -i --colors --verbose --detectOpenHandles",
    "test:unit": "jest tests/unit -i --colors --verbose",
    "test:integration": "jest tests/integration -i --colors --verbose",
    "test:e2e": "playwright test",
    "test:performance": "node tests/performance/load-test.js",
    "test:all": "yarn test:unit && yarn test:integration && yarn test:e2e && yarn test:performance",
    "test:production": "cross-env NODE_ENV=production yarn test:all",
    "dev:local": "cross-env NODE_ENV=test PORT=5001 nodemon src/index.js",
    "test:watch": "jest -i --watchAll",
    "coverage": "jest -i --coverage",
    "coverage:ci": "jest -i --coverage --coverageReporters=text-lcov --silent",
    "coverage:coveralls": "jest -i --coverage --coverageReporters=text-lcov | coveralls",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --check **/*.js",
    "prettier:fix": "prettier --write **/*.js",
    "docker:prod": "docker-compose -f docker-compose.yml -f docker-compose.prod.yml up",
    "docker:dev": "docker-compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "docker:test": "docker-compose -f docker-compose.yml -f docker-compose.test.yml up",
    "playwright:install": "playwright install",
    "migrate:orders": "node scripts/migrate-orders.js",
    "health:check": "node scripts/health-check.js",
    "seed:test-data": "node scripts/seed-test-data.js",
    "validate:production": "node scripts/validate-production-readiness.js",
    "prepare": "command -v husky >/dev/null 2>&1 && husky install || true"
  },
  "keywords": [
    "node",
    "node.js",
    "boilerplate",
    "generator",
    "express",
    "rest",
    "api",
    "mongodb",
    "mongoose",
    "es6",
    "es7",
    "es8",
    "es9",
    "jest",
    "travis",
    "docker",
    "passport",
    "joi",
    "eslint",
    "prettier"
  ],
  "dependencies": {
    "@aws-sdk/client-s3": "^3.345.0",
    "@google-cloud/storage": "^7.11.1",
    "@sendgrid/mail": "^8.1.5",
    "@sentry/node": "^7.77.0",
    "@sentry/profiling-node": "^10.32.1",
    "airtable": "^0.12.2",
    "archiver": "^7.0.1",
    "aws-sdk": "^2.1418.0",

    "cross-env": "^7.0.0",
    "crypto-js": "4.2.0",
    "date-fns": "^2.30.0",
    "dotenv": "^10.0.0",
    "express": "^4.17.1",
    "express-mongo-sanitize": "^2.0.0",
    "express-rate-limit": "^5.0.0",
    "faker": "^5.5.3",
    "firebase-admin": "^13.4.0",
    "googleapis": "^137.1.0",
    "helmet": "^4.1.0",
    "html-pdf": "^3.0.1",
